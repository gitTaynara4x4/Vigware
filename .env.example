APP_NAME=Vigware Cloud
APP_ENV=dev
CORS_ORIGINS=*

# Local dev com SQLite:
DATABASE_URL=sqlite:///./vigware_dev.db

# Produção PostgreSQL:
# DATABASE_URL=postgresql+psycopg://USUARIO:SENHA@HOST:5432/BANCO?sslmode=prefer

# Em produção, preencha e mantenha true.
VIGWARE_RECEIVER_KEY=troque-por-uma-chave-grande
REQUIRE_RECEIVER_KEY=false
