APP_NAME=Vigware Cloud
APP_ENV=prod

# Troque pelo endereço público do seu Vigware.
# Pode ser * no primeiro teste, depois coloque o domínio certo.
CORS_ORIGINS=*

# Banco PostgreSQL da VPS/EasyPanel.
# Use postgresql+psycopg:// para usar psycopg v3.
DATABASE_URL=postgresql+psycopg://USUARIO:SENHA@HOST:5432/BANCO?sslmode=prefer

# Chave forte para o PC do Active Net/JFL enviar eventos para a VPS.
# Gere uma chave grande e coloque a mesma no bridge/config.json.
VIGWARE_RECEIVER_KEY=COLOQUE_UMA_CHAVE_FORTE_AQUI
REQUIRE_RECEIVER_KEY=true
