APP_NAME=Vigware Cloud
APP_ENV=prod
CORS_ORIGINS=*

# Banco PostgreSQL da VPS/EasyPanel.
# Use postgresql+psycopg:// para usar psycopg v3.
DATABASE_URL=postgresql+psycopg://USUARIO:SENHA@HOST:5432/BANCO?sslmode=prefer

# Receiver profissional: HMAC por bridge/transmissor.
REQUIRE_RECEIVER_KEY=true
RECEIVER_AUTH_MODE=hmac
RECEIVER_ALLOWED_DRIFT_SECONDS=300

# Um bridge local do Active Net/JFL.
# O bridge_id precisa ser igual ao bridge/config.json.
# O bridge_secret precisa ser igual ao bridge/config.json.
VIGWARE_BRIDGE_ID=activenet-matriz
VIGWARE_BRIDGE_SECRET=TROQUE_POR_UMA_CHAVE_GRANDE_IGUAL_A_DO_BRIDGE

# Alternativa para vários bridges:
# VIGWARE_BRIDGE_SECRETS={"activenet-matriz":"segredo1","activenet-filial":"segredo2"}

# Modo antigo, só se RECEIVER_AUTH_MODE=simple.
VIGWARE_RECEIVER_KEY=
